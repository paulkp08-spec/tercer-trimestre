/*
  Práctica: BME680 + ESP32
  Mide: Temperatura, Humedad, Presión, Gas VOC
  I2C: SDA=GPIO21, SCL=GPIO22
*/

#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

#define BME680_ADDR 0x76          // SDO=GND → 0x76 | SDO=3.3V → 0x77
#define SEALEVELPRESSURE_HPA (1013.25)

Adafruit_BME680 bme;

void setup() {
  Serial.begin(115200);
  while (!Serial);

  Serial.println("=== BME680 + ESP32 ===");

  if (!bme.begin(BME680_ADDR)) {
    Serial.println("ERROR: BME680 no encontrado. Revisa el cableado.");
    while (1);
  }
  Serial.println("BME680 detectado!");

  // Configuración de oversampling y filtros
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme.setGasHeater(320, 150); // 320°C por 150ms

  delay(1000);
}

void loop() {
  if (!bme.performReading()) {
    Serial.println("Error al leer el sensor");
    delay(2000);
    return;
  }

  Serial.print("Temperatura : ");
  Serial.print(bme.temperature);
  Serial.println(" °C");

  Serial.print("Humedad     : ");
  Serial.print(bme.humidity);
  Serial.println(" %");

  Serial.print("Presion     : ");
  Serial.print(bme.pressure / 100.0);
  Serial.println(" hPa");

  Serial.print("Altitud     : ");
  Serial.print(bme.readAltitude(SEALEVELPRESSURE_HPA));
  Serial.println(" m");

  Serial.print("Gas VOC     : ");
  Serial.print(bme.gas_resistance / 1000.0);
  Serial.println(" KOhm");

  Serial.println("--------------------");
  delay(2000);
}
